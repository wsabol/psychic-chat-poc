{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowListSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:ListSecrets"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowGetSecretValue",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret",
        "secretsmanager:PutSecretValue",
        "secretsmanager:UpdateSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:us-east-1:586337033065:secret:psychic-chat/*",
        "arn:aws:secretsmanager:us-east-1:586337033065:secret:apple-iap*"
      ]
    }
  ]
}
